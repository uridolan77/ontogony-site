---
import { getEntry } from 'astro:content';

type Collection = 'concepts' | 'essays' | 'paths';

interface Props {
  heading?: string;
  concepts?: string[];
  essays?: string[];
  paths?: string[];
}

const {
  heading = 'Where to next',
  concepts = [],
  essays = [],
  paths = [],
} = Astro.props;

const kindLabels: Record<Collection, string> = {
  concepts: 'Concept',
  essays: 'Essay',
  paths: 'Path',
};

async function resolve(collection: Collection, slugs: string[]) {
  const items = await Promise.all(
    slugs.map(async (slug) => {
      const entry = await getEntry(collection, slug);
      if (!entry) return null;
      return {
        href: `/${collection}/${slug}`,
        title: entry.data.title,
        kind: collection,
      };
    }),
  );
  return items.filter((item): item is NonNullable<typeof item> => item !== null);
}

const items = [
  ...(await resolve('concepts', concepts)),
  ...(await resolve('essays', essays)),
  ...(await resolve('paths', paths)),
];
---

{
  items.length > 0 && (
    <section class="next-steps">
      <hr />
      <p class="kicker">{heading}</p>
      <ul class="next-steps-list">
        {items.map((item) => (
          <li>
            <span class="next-steps-kind">{kindLabels[item.kind]}</span>
            <a href={item.href}>{item.title}</a>
          </li>
        ))}
      </ul>
    </section>
  )
}
