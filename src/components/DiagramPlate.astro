---
interface Props {
  title: string;
  caption: string;
  image: string;
  href: string;
  label?: string;
}

const {
  title,
  caption,
  image,
  href,
  label = 'DIAGRAM',
} = Astro.props as Props;
---

<figure class="diagram-plate">
  <a class="image-link" href={href}>
    <img src={image} alt={title} loading="lazy" decoding="async" />
  </a>
  <figcaption>
    <p class="plate-label">{label}</p>
    <h2 class="plate-title"><a href={href}>{title}</a></h2>
    <p class="plate-caption">{caption}</p>
    <p class="plate-link"><a href={href}>Open full diagram ·→</a></p>
  </figcaption>
</figure>

<style>
  .diagram-plate {
    margin: 40px 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-paper-2);
    padding: 18px;
    display: grid;
    gap: 14px;
  }

  .image-link {
    display: block;
    border: 1px solid var(--color-rule);
    background: var(--color-paper);
  }

  .image-link img {
    display: block;
    width: 100%;
    height: auto;
  }

  .plate-label {
    margin: 0 0 8px;
    font-size: 11px;
    letter-spacing: 0.11em;
    color: var(--color-ink-muted);
  }

  .plate-title {
    margin: 0;
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    line-height: 1.25;
  }

  .plate-title a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }

  .plate-title a:hover {
    border-bottom-color: var(--color-rule-strong);
  }

  .plate-caption {
    margin: 8px 0 0;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }

  .plate-link {
    margin: 10px 0 0;
    font-size: 0.95rem;
  }

  .plate-link a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
  }

  .plate-link a:hover {
    border-bottom-color: var(--color-rule-strong);
  }
  @media (max-width: 700px) {
    .diagram-plate {
      padding: 14px;
      margin: 30px 0;
    }
  }
</style>