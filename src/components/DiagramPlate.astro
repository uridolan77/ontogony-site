---
interface Props {
  title: string;
  caption: string;
  image: string;
  href: string;
  label?: string;
  expandLabel?: string;
  openLabel?: string;
}

const {
  title,
  caption,
  image,
  href,
  label = 'DIAGRAM',
  expandLabel = 'Expand',
  openLabel = 'Open diagram page',
} = Astro.props as Props;

const modalId = `diagram-modal-${Math.random().toString(36).slice(2, 10)}`;
---

<figure class="diagram-plate" data-diagram-plate>
  <div class="image-shell">
    <button
      class="image-button"
      type="button"
      aria-expanded="false"
      aria-controls={modalId}
      data-expand-trigger
    >
      <img src={image} alt={title} loading="lazy" decoding="async" />
    </button>
    <div class="image-actions" aria-label="Diagram actions">
      <button
        class="overlay-button"
        type="button"
        aria-expanded="false"
        aria-controls={modalId}
        data-expand-trigger
      >
        {expandLabel}
      </button>
      <a class="overlay-button" href={href}>{openLabel}</a>
    </div>
  </div>
  <figcaption>
    <p class="plate-label">{label}</p>
    <h2 class="plate-title"><a href={href}>{title}</a></h2>
    <p class="plate-caption">{caption}</p>
  </figcaption>
</figure>

<div
  id={modalId}
  class="diagram-modal"
  role="dialog"
  aria-modal="true"
  aria-label={`Expanded diagram: ${title}`}
  hidden
  data-diagram-modal
>
  <div class="modal-backdrop" data-close-trigger></div>
  <div class="modal-panel">
    <div class="modal-frame">
      <button class="close-button" type="button" aria-label={`Close expanded diagram: ${title}`} data-close-trigger>
        Close
      </button>
      <img src={image} alt={title} loading="eager" decoding="async" />
      <div class="modal-meta">
        <p class="modal-label">{label}</p>
        <h2>{title}</h2>
        <p>{caption}</p>
        <a href={href}>{openLabel} ·→</a>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ modalId }}>
  (() => {
    const modal = document.getElementById(modalId);
    if (!modal) return;

    const plate = modal.previousElementSibling;
    if (!(plate instanceof HTMLElement)) return;

    const expandButtons = plate.querySelectorAll('[data-expand-trigger]');
    const closeTargets = modal.querySelectorAll('[data-close-trigger]');
    const closeButton = modal.querySelector('.close-button');
    let previousOverflow = '';

    const setExpanded = (expanded) => {
      expandButtons.forEach((button) => {
        if (button instanceof HTMLElement) {
          button.setAttribute('aria-expanded', String(expanded));
        }
      });
    };

    const open = () => {
      previousOverflow = document.body.style.overflow;
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      setExpanded(true);
      if (closeButton instanceof HTMLElement) closeButton.focus();
    };

    const close = () => {
      modal.hidden = true;
      document.body.style.overflow = previousOverflow;
      setExpanded(false);
    };

    expandButtons.forEach((button) => {
      button.addEventListener('click', open);
    });

    closeTargets.forEach((target) => {
      target.addEventListener('click', close);
    });

    modal.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.closest('.modal-frame')) return;
      close();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !modal.hidden) {
        close();
      }
    });
  })();
</script>

<style>
  .diagram-plate {
    margin: 40px 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    background: var(--color-paper-2);
    padding: 18px;
    display: grid;
    gap: 14px;
  }

  .image-button {
    display: block;
    position: relative;
    z-index: 0;
    width: 100%;
    border: 1px solid var(--color-rule);
    background: var(--color-paper);
    padding: 0;
    margin: 0;
    cursor: zoom-in;
  }

  .image-button img {
    display: block;
    width: 100%;
    height: auto;
  }

  .image-shell {
    position: relative;
  }

  .image-shell::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: color-mix(in srgb, var(--color-ink) 8%, transparent);
    opacity: 0;
    pointer-events: none;
    transition: opacity 160ms ease;
  }

  .image-shell:hover::after,
  .image-shell:focus-within::after {
    opacity: 1;
  }

  .image-actions {
    position: absolute;
    right: 12px;
    top: 12px;
    z-index: 2;
    display: flex;
    gap: 8px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    pointer-events: none;
    transition: opacity 160ms ease, transform 160ms ease, visibility 160ms ease;
  }

  .image-shell:hover .image-actions,
  .image-shell:focus-within .image-actions {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .overlay-button {
    font: inherit;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink);
    text-decoration: none;
    border: 1px solid var(--color-rule-strong);
    background: color-mix(in srgb, var(--color-paper) 94%, transparent);
    backdrop-filter: blur(1px);
    padding: 6px 10px;
    line-height: 1;
    white-space: nowrap;
    border-radius: 2px;
    display: inline-flex;
    align-items: center;
  }

  button.overlay-button {
    cursor: pointer;
  }

  .overlay-button:hover,
  .overlay-button:active {
    color: var(--color-ink);
    background: var(--color-paper);
  }

  .plate-label {
    margin: 0 0 8px;
    font-size: 11px;
    letter-spacing: 0.11em;
    color: var(--color-ink-muted);
  }

  .plate-title {
    margin: 0;
    font-size: clamp(1.1rem, 1.6vw, 1.35rem);
    line-height: 1.25;
  }

  .plate-title a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }

  .plate-title a:hover {
    border-bottom-color: var(--color-rule-strong);
  }

  .plate-caption {
    margin: 8px 0 0;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }

  .image-button:focus-visible,
  .overlay-button:focus-visible,
  .close-button:focus-visible,
  .modal-meta a:focus-visible {
    outline: 2px solid var(--color-active);
    outline-offset: 2px;
  }

  .diagram-modal {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: grid;
    place-items: center;
    padding: clamp(16px, 3vw, 48px);
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-ink) 72%, transparent);
    backdrop-filter: blur(2px);
  }

  .modal-panel {
    position: relative;
    width: min(96vw, 1680px);
    z-index: 1;
  }

  .modal-frame {
    border: 1px solid var(--color-rule);
    background: var(--color-paper);
    box-shadow: 0 20px 50px color-mix(in srgb, var(--color-ink) 20%, transparent);
    padding: clamp(12px, 1.6vw, 20px);
  }

  .close-button {
    display: inline-flex;
    margin: 0 0 12px auto;
    font: inherit;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: transparent;
    color: var(--color-ink-soft);
    border: 0;
    border-bottom: 1px solid var(--color-rule);
    cursor: pointer;
    padding: 0;
  }

  .close-button:hover {
    color: var(--color-ink);
    border-bottom-color: var(--color-rule-strong);
  }

  .modal-frame img {
    display: block;
    width: 100%;
    max-width: min(96vw, 1600px);
    max-height: 86vh;
    margin: 0 auto;
    object-fit: contain;
    border: 1px solid var(--color-rule);
    background: var(--color-paper);
  }

  .modal-meta {
    margin-top: 12px;
    border-top: 1px solid var(--color-rule);
    padding-top: 10px;
  }

  .modal-label {
    margin: 0 0 8px;
    font-size: 11px;
    letter-spacing: 0.11em;
    color: var(--color-ink-muted);
  }

  .modal-meta h2 {
    margin: 0;
    font-size: clamp(1.05rem, 1.7vw, 1.35rem);
    line-height: 1.25;
  }

  .modal-meta p {
    margin: 8px 0 0;
    color: var(--color-ink-soft);
    line-height: 1.5;
  }

  .modal-meta a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    display: inline-block;
    margin-top: 10px;
    font-size: 0.86rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .modal-meta a:hover {
    border-bottom-color: var(--color-rule-strong);
  }

  @media (prefers-reduced-motion: no-preference) {
    .diagram-modal {
      animation: modal-fade 160ms ease-out;
    }

    .modal-panel {
      animation: modal-rise 180ms ease-out;
      transform-origin: center;
    }
  }

  @keyframes modal-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes modal-rise {
    from {
      opacity: 0;
      transform: scale(0.985);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (max-width: 700px) {
    .diagram-plate {
      padding: 14px;
      margin: 30px 0;
    }

    .modal-frame {
      padding: 10px;
    }

    .modal-meta a {
      font-size: 0.78rem;
    }
  }

  @media (hover: none) {
    .image-shell::after {
      opacity: 1;
    }

    .image-actions {
      opacity: 1;
      visibility: visible;
      transform: none;
      pointer-events: auto;
    }
  }
</style>