---
interface Props {
  kind?: string;
  detail?: string;
  active?: string;
}

const { kind, detail, active } = Astro.props;
---

<header class="instrument-bar">
  <div class="inner">
    <a class="wordmark" href="/">ONTOGONY <em>a field guide</em></a>
    <div class="readouts">
      {kind && <span>{kind}</span>}
      {detail && <span class="gold">{detail}</span>}
      {active && <span class="active">{active}</span>}
    </div>
  </div>
</header>
