---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Reading paths"
  description="Curated traversals across the strata of Ontogony."
  kind="PATHS"
  active="IN PROGRESS"
>
  <p class="micro" style="color: var(--color-ink-muted); margin: 0 0 18px;">READING PATHS</p>
  <h1 class="h1">Reading paths.</h1>
  <p class="standfirst" style="margin-top: 22px; max-width: 60ch;">
    Curated traversals across the field guide. Each path threads a sequence
    of essays and concept entries with a clear destination. The first paths
    arrive shortly.
  </p>

  <Fragment slot="margin-notes">
    <div class="note">
      <span class="label">STATUS</span>
      Templates ready, paths in composition.
    </div>
  </Fragment>
</BaseLayout>
