---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublished, isLinkable } from '../../lib/content';

type Stratum = 'R1' | 'R2' | 'R3' | 'R4';

export async function getStaticPaths() {
  const published = (await getPublished('concepts')).sort(
    (a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
  );
  // Cross-reference lookups (related, whereNext) need every entry by id,
  // including drafts, so titles resolve even when the target won't render
  // its own page in production. Routing only generates published entries.
  const all = await getCollection('concepts');
  const essays = await getCollection('essays');
  const paths = await getCollection('paths');
  const diagrams = await getCollection('diagrams');
  return published.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, all, essays, paths, diagrams },
  }));
}

const { entry, all, essays, paths, diagrams } = Astro.props;
const { Content } = await render(entry);

const byId = new Map(all.map((c) => [c.id, c]));
const essaysById = new Map(essays.map((e) => [e.id, e]));
const pathsById = new Map(paths.map((p) => [p.id, p]));
const diagramsById = new Map(diagrams.map((d) => [d.id, d]));

const related = (entry.data.related ?? [])
  .map((slug) => byId.get(slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c))
  .map((c) => ({
    entry: c,
    linkable: isLinkable(c),
  }));

const stratumName: Record<Stratum, string> = {
  R1: 'FIELD',
  R2: 'BIOLOGICAL',
  R3: 'COGNITIVE',
  R4: 'INSTITUTIONAL',
};
const stratumGloss: Record<Stratum, string> = {
  R1: 'pre-individual',
  R2: 'metabolic-closure',
  R3: 'neural-integrative',
  R4: 'symbolic-political',
};

const register = entry.data.register;
const order = entry.data.order;
const total = all.length;

const orderLabel =
  typeof order === 'number'
    ? `${String(order).padStart(3, '0')} / ${String(total).padStart(3, '0')}`
    : undefined;

const sourceLabel =
  entry.data.chapterNumber && entry.data.bookTitle
    ? `Chapter ${entry.data.chapterNumber} — ${entry.data.bookTitle}`
    : entry.data.chapterNumber
      ? `Chapter ${entry.data.chapterNumber}`
      : entry.data.bookTitle;

const kickerLine =
  typeof order === 'number'
    ? `CONCEPT · ENTRY ${String(order).padStart(3, '0')} · ${register} ${stratumName[register]}`
    : `CONCEPT · ${register} ${stratumName[register]}`;

const whereNext = (entry.data.whereNext ?? []).map((step) => {
  let title = step.title;
  let metaSuffix = '';
  let href: string | undefined;
  let targetIsDraft = false;

  if (step.kind === 'concept') {
    const c = byId.get(step.slug);
    if (c) {
      title = title ?? c.data.title;
      metaSuffix = ` · ${c.data.register}`;
      targetIsDraft = !isLinkable(c);
    } else {
      title = title ?? step.slug;
    }
    href = `/concepts/${step.slug}`;
  } else if (step.kind === 'essay') {
    const e = essaysById.get(step.slug);
    if (e) {
      title = title ?? e.data.title;
      if (e.data.register) metaSuffix = ` · ${e.data.register}`;
      targetIsDraft = !isLinkable(e);
    } else if (!title) {
      title = step.slug;
    }
    href = `/essays/${step.slug}`;
  } else if (step.kind === 'path') {
    const p = pathsById.get(step.slug);
    if (p) {
      title = title ?? p.data.title;
      targetIsDraft = !isLinkable(p);
    } else if (!title) {
      title = step.slug;
    }
    href = `/paths/${step.slug}`;
  } else {
    const d = diagramsById.get(step.slug);
    if (d) {
      title = title ?? d.data.title;
      targetIsDraft = !isLinkable(d);
    } else if (!title) {
      title = step.slug;
    }
    href = `/diagrams/${step.slug}`;
  }

  if (import.meta.env.PROD && targetIsDraft) href = undefined;

  const meta = `${step.kind.toUpperCase()}${metaSuffix}`;

  return { href, title: title!, why: step.why, meta, linkable: Boolean(href) };
});
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.short}
  kind="CONCEPT"
  detail={`${register} · ${stratumName[register]}`}
  active={orderLabel}
  currentStratum={register}
  narrow
>
  <p class="micro" style="color: var(--color-ink-muted); margin: 0 0 18px;">{kickerLine}</p>
  <h1 class="h1">{entry.data.title}</h1>
  <p class="standfirst" style="margin-top: 22px;">{entry.data.short}</p>

  <dl class="ledger">
    <div class="ledger-row">
      <dt>Register</dt>
      <dd>
        <span class="tag plain">{register}</span> &nbsp;
        <span class="muted">{stratumName[register].toLowerCase()} — {stratumGloss[register]}.</span>
      </dd>
    </div>

    {entry.data.burnRate && (
      <div class="ledger-row">
        <dt>Burn rate</dt>
        <dd>{entry.data.burnRate}</dd>
      </div>
    )}

    {entry.data.cessation && (
      <div class="ledger-row">
        <dt>Cessation signature</dt>
        <dd>{entry.data.cessation}</dd>
      </div>
    )}

    {entry.data.genealogy.length > 0 && (
      <div class="ledger-row">
        <dt>Genealogy</dt>
        <dd>{entry.data.genealogy.join(' · ')}</dd>
      </div>
    )}

    {sourceLabel && (
      <div class="ledger-row">
        <dt>Appears in</dt>
        <dd><span class="muted">{sourceLabel}</span></dd>
      </div>
    )}

    {related.length > 0 && (
      <div class="ledger-row">
        <dt>Related</dt>
        <dd>
          {related.map((rel, i) => (
            <>
              {i > 0 && ' · '}
              {rel.linkable ? (
                <a class="link" href={`/concepts/${rel.entry.id}`}>{rel.entry.data.title}</a>
              ) : (
                <span class="muted">{rel.entry.data.title}</span>
              )}
            </>
          ))}
        </dd>
      </div>
    )}

    {entry.data.notThis.length > 0 && (
      <div class="ledger-row">
        <dt>What it is not</dt>
        <dd>
          <ul>
            {entry.data.notThis.map((n) => <li>{n}</li>)}
          </ul>
        </dd>
      </div>
    )}

    {whereNext.length > 0 && (
      <div class="ledger-row last">
        <dt>Where next</dt>
        <dd>
          <div class="where-next">
            {whereNext.map((w) => (
              w.linkable ? (
                <a class="next" href={w.href}>
                  <span class="next-title">
                    {w.title}
                    {w.why && <em>{w.why}</em>}
                  </span>
                  <span class="next-meta">{w.meta}</span>
                  <span class="next-arrow">·→</span>
                </a>
              ) : (
                <div class="next" aria-disabled="true">
                  <span class="next-title">
                    {w.title}
                    {w.why && <em>{w.why}</em>}
                  </span>
                  <span class="next-meta">{w.meta}</span>
                </div>
              )
            ))}
          </div>
        </dd>
      </div>
    )}
  </dl>

  <div class="body" style="margin-top: 56px;">
    <Content />
  </div>

  <Fragment slot="margin-notes">
    <div class="note">
      <span class="label">REGISTER</span>
      {register} · {stratumName[register].toLowerCase()} — {stratumGloss[register]}.
    </div>
    {entry.data.genealogy.length > 0 && (
      <div class="note">
        <span class="label">GENEALOGY</span>
        {entry.data.genealogy.join(' · ')}.
      </div>
    )}
    {related.length > 0 && (
      <div class="note">
        <span class="label">RELATED</span>
        {related.map((rel, i) => (
          <>
            {i > 0 && ' · '}
            {rel.linkable ? (
              <a class="link" href={`/concepts/${rel.entry.id}`}>{rel.entry.data.title}</a>
            ) : (
              <span class="muted">{rel.entry.data.title}</span>
            )}
          </>
        ))}
      </div>
    )}
    <div class="note">
      <span class="label">PROTOCOL</span>
      Hold throughput conditions fixed; record the order in which
      macrovariables drop out. The sequence is the regime.
    </div>
  </Fragment>
</BaseLayout>
