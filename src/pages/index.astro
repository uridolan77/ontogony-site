---
import BaseLayout from '../layouts/BaseLayout.astro';

const beginItems = [
  {
    href: '/theory',
    title: 'Theory overview',
    def: 'The five-minute orientation to Ontogony.',
  },
  {
    href: '/concepts',
    title: 'Concept atlas',
    def: 'The vocabulary of Ontogony, one term at a time.',
  },
  {
    href: '/concepts/transduction',
    title: 'Transduction',
    def: 'The operator the rest of the framework is built on.',
  },
];
---

<BaseLayout
  description="A field guide to the Transductive Universe."
  kind="HOME"
  active="v0.1"
>
  <section class="home-hero">
    <h1 class="home-title">A Field Guide to the Transductive Universe</h1>
    <p class="home-subtitle">
      A theory of becoming — about what it costs for anything to be the kind
      of thing it is, and how new kinds of things come into being at all.
    </p>
  </section>

  <hr />

  <section>
    <p class="kicker">Begin</p>
    <ul class="ledger-list">
      {
        beginItems.map((item) => (
          <li>
            <a class="ledger-row" href={item.href}>
              <span class="ledger-row-title">{item.title}</span>
              <span class="ledger-row-def">{item.def}</span>
              <span class="ledger-row-marker" aria-hidden="true">·→</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
