---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublished, isLinkable } from '../../lib/content';
import PullQuote from '../../components/mdx/PullQuote.astro';
import SectionGlyph from '../../components/mdx/SectionGlyph.astro';
import FootnoteMarker from '../../components/mdx/FootnoteMarker.astro';

const mdxComponents = { PullQuote, SectionGlyph, FootnoteMarker };

type Stratum = 'R1' | 'R2' | 'R3' | 'R4';

export async function getStaticPaths() {
  const entries = await getPublished('essays');
  // Reference collections kept unfiltered so title lookups still resolve
  // in dev, while production link output can suppress draft targets.
  const concepts = await getCollection('concepts');
  const essays = await getCollection('essays');
  const paths = await getCollection('paths');
  const diagrams = await getCollection('diagrams');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, concepts, essays, paths, diagrams },
  }));
}

const { entry, concepts, essays, paths, diagrams } = Astro.props;
const { Content } = await render(entry);

const stratumName: Record<Stratum, string> = {
  R1: 'FIELD',
  R2: 'BIOLOGICAL',
  R3: 'COGNITIVE',
  R4: 'INSTITUTIONAL',
};

const conceptById = new Map(concepts.map((c) => [c.id, c]));
const essayById = new Map(essays.map((e) => [e.id, e]));
const pathById = new Map(paths.map((p) => [p.id, p]));
const diagramById = new Map(diagrams.map((d) => [d.id, d]));
const cited = (entry.data.cites ?? [])
  .map((slug) => conceptById.get(slug))
  .filter((c): c is NonNullable<typeof c> => Boolean(c))
  .map((c) => ({
    entry: c,
    linkable: isLinkable(c),
  }));

const register = entry.data.register;
const number = entry.data.number;
const readingTime = entry.data.readingTime;

const kindLabel = number ? `ESSAY · ${String(number).padStart(2, '0')}` : 'ESSAY';
const detail =
  register !== undefined ? `${register} · ${stratumName[register]}` : undefined;
const active = readingTime ? `~${readingTime} MIN` : undefined;

const whereNext = (entry.data.whereNext ?? []).map((step) => {
  let title = step.title;
  let metaSuffix = '';
  let href: string | undefined;
  let targetIsDraft = false;

  if (step.kind === 'concept') {
    const c = conceptById.get(step.slug);
    if (c) {
      title = title ?? c.data.title;
      metaSuffix = ` · ${c.data.register}`;
      targetIsDraft = !isLinkable(c);
    } else {
      title = title ?? step.slug;
    }
    href = `/concepts/${step.slug}`;
  } else if (step.kind === 'essay') {
    const e = essayById.get(step.slug);
    if (e) {
      title = title ?? e.data.title;
      if (e.data.register) metaSuffix = ` · ${e.data.register}`;
      targetIsDraft = !isLinkable(e);
    } else if (!title) {
      title = step.slug;
    }
    href = `/essays/${step.slug}`;
  } else if (step.kind === 'path') {
    const p = pathById.get(step.slug);
    if (p) {
      title = title ?? p.data.title;
      targetIsDraft = !isLinkable(p);
    } else if (!title) {
      title = step.slug;
    }
    href = `/paths/${step.slug}`;
  } else {
    const d = diagramById.get(step.slug);
    if (d) {
      title = title ?? d.data.title;
      targetIsDraft = !isLinkable(d);
    } else if (!title) {
      title = step.slug;
    }
    href = `/diagrams/${step.slug}`;
  }

  if (import.meta.env.PROD && targetIsDraft) href = undefined;

  return {
    href,
    title: title!,
    why: step.why,
    meta: `${step.kind.toUpperCase()}${metaSuffix}`,
    linkable: Boolean(href),
  };
});

const dateLabel = entry.data.date
  ? entry.data.date.toLocaleDateString('en-GB', {
      year: 'numeric',
      month: 'long',
    })
  : undefined;

const sourceLabel =
  entry.data.chapterNumber && entry.data.bookTitle
    ? `Chapter ${entry.data.chapterNumber} — ${entry.data.bookTitle}`
    : entry.data.chapterNumber
      ? `Chapter ${entry.data.chapterNumber}`
      : entry.data.bookTitle;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  kind={kindLabel}
  detail={detail}
  active={active}
  currentStratum={register}
>
  <p class="micro" style="color: var(--color-ink-muted); margin: 0 0 18px;">
    {kindLabel}{number ? ' · OPENING ORIENTATION' : ''}
  </p>
  <h1 class="h1">{entry.data.title}.</h1>
  <p class="standfirst" style="margin-top: 24px;">{entry.data.summary}</p>

  <div class="body" style="margin-top: 40px;">
    <Content components={mdxComponents} />
  </div>

  <dl class="ledger">
    {number && (
      <div class="ledger-row">
        <dt>Essay</dt>
        <dd>
          {String(number).padStart(2, '0')} · {entry.data.title}
          {readingTime && (
            <span class="muted"> — opening orientation, ~{readingTime} min</span>
          )}
        </dd>
      </div>
    )}
    {dateLabel && (
      <div class="ledger-row">
        <dt>Authored</dt>
        <dd>{dateLabel}</dd>
      </div>
    )}
    {register && (
      <div class="ledger-row">
        <dt>Register focus</dt>
        <dd>
          <span class="tag plain">{register}</span> &nbsp;
          <span class="muted">{stratumName[register].toLowerCase()}.</span>
        </dd>
      </div>
    )}
    {cited.length > 0 && (
      <div class="ledger-row">
        <dt>Cites</dt>
        <dd>
          {cited.map((c, i) => (
            <>
              {i > 0 && ' · '}
              {c.linkable ? (
                <a class="link" href={`/concepts/${c.entry.id}`}>{c.entry.data.title}</a>
              ) : (
                <span class="muted">{c.entry.data.title}</span>
              )}
            </>
          ))}
        </dd>
      </div>
    )}
    {sourceLabel && (
      <div class="ledger-row">
        <dt>Source</dt>
        <dd>{sourceLabel}</dd>
      </div>
    )}
    {whereNext.length > 0 && (
      <div class="ledger-row last">
        <dt>Where next</dt>
        <dd>
          <div class="where-next">
            {whereNext.map((w) => (
              w.linkable ? (
                <a class="next" href={w.href}>
                  <span class="next-title">
                    {w.title}
                    {w.why && <em>{w.why}</em>}
                  </span>
                  <span class="next-meta">{w.meta}</span>
                  <span class="next-arrow">·→</span>
                </a>
              ) : (
                <div class="next" aria-disabled="true">
                  <span class="next-title">
                    {w.title}
                    {w.why && <em>{w.why}</em>}
                  </span>
                  <span class="next-meta">{w.meta}</span>
                </div>
              )
            ))}
          </div>
        </dd>
      </div>
    )}
  </dl>

  <Fragment slot="margin-notes">
    {
      entry.data.footnotes.map((fn, i) => {
        const sup = ['¹', '²', '³', '⁴', '⁵', '⁶', '⁷', '⁸', '⁹'][i] ?? String(i + 1);
        return (
          <div class="note" id={fn.id}>
            <span class="label">FOOTNOTE · {sup}</span>
            {fn.body}
          </div>
        );
      })
    }
    {register && (
      <div class="note">
        <span class="label">REGISTER</span>
        {register} · {stratumName[register].toLowerCase()}.
      </div>
    )}
    <div class="note">
      <span class="label">PROTOCOL</span>
      Hold environment fixed. Reduce throughput. Record the order of
      macrovariable collapse. The sequence <em>is</em> the regime.
    </div>
  </Fragment>
</BaseLayout>
