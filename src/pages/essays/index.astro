---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Essays"
  description="Long-form essays — opening orientations and case studies."
  kind="ESSAYS"
  active="IN PROGRESS"
>
  <p class="micro" style="color: var(--color-ink-muted); margin: 0 0 18px;">ESSAYS</p>
  <h1 class="h1">Essays.</h1>
  <p class="standfirst" style="margin-top: 22px; max-width: 60ch;">
    Long-form orientations and case studies. The first essays land with the
    next content drop; the schema and templates that carry them are already
    in place.
  </p>

  <Fragment slot="margin-notes">
    <div class="note">
      <span class="label">STATUS</span>
      Templates ready, content writing.
    </div>
  </Fragment>
</BaseLayout>
