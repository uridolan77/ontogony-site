---
import NoRailLayout from '../layouts/NoRailLayout.astro';
import ALFloysApp from '../components/ALFloysApp';
---

<NoRailLayout
  title="AL.Floys"
  description="Interactive artificial life playground featuring boids, ecosystem evolution, Lenia, Physarum, Turing reaction-diffusion, and N-body gravity."
  kind="PLAYGROUND"
  detail="ARTIFICIAL LIFE"
>
  <div class="al-header-band">
    <div class="al-intro">
      <h1>AL.Floys</h1>
      <p>
        An interactive artificial-life laboratory. Six simulation kernels — flocking boids,
        genetic ecosystems, Lenia continuous automata, Physarum slime-mold, Turing
        reaction-diffusion, and N-body gravity — running live in your browser.
        Double-click any particle to track it; use the controls panel to tune physics in real time.
      </p>
    </div>
  </div>

  <div class="al-embed">
    <ALFloysApp client:only="react" />
  </div>
</NoRailLayout>

<style>
  body {
    margin: 0;
    background: var(--color-paper, #faf9f6);
    color: var(--color-ink, #1a1a18);
    font-family: var(--font-sans, system-ui, sans-serif);
  }

  .al-header-band {
    max-width: 1280px;
    margin: 0 auto;
    padding: 48px 32px 32px;
  }

  .al-intro {
    flex: 1;
    min-width: 0;
  }

  .al-intro h1 {
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
  }

  .al-intro p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-ink-muted, #555);
    max-width: 68ch;
    margin: 0;
  }

  .al-embed {
    width: min(1160px, calc(100vw - 96px));
    aspect-ratio: 16 / 9;
    min-height: 420px;
    max-height: 680px;
    margin: 0 auto 56px;
    border: 1px solid var(--color-rule, #e0ddd6);
    border-radius: 10px;
    background: var(--color-paper, #faf9f6);
    box-shadow: 0 20px 48px rgba(20, 16, 8, 0.12);
    overflow: hidden;
    transition:
      width 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      height 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      border-radius 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(body.alfloys-fullview) .al-embed {
    position: fixed;
    top: 68px;
    left: 24px;
    right: 24px;
    bottom: 24px;
    width: auto;
    height: auto;
    max-height: none;
    min-height: 0;
    margin: 0;
    z-index: 50;
    border-radius: 12px;
    border: 1px solid var(--color-rule-strong, #cbc6bd);
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.28);
  }

  :global(body.alfloys-fullview) {
    overflow: hidden;
  }

  @media (max-width: 760px) {
    .al-header-band {
      padding: 32px 16px 20px;
    }

    .al-embed {
      width: calc(100vw - 24px);
      min-height: 320px;
      margin-bottom: 24px;
      border-radius: 8px;
    }

    :global(body.alfloys-fullview) .al-embed {
      top: 60px;
      left: 8px;
      right: 8px;
      bottom: 8px;
      border-radius: 10px;
    }
  }
</style>
