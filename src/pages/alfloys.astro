---
import '../styles/global.css';
import ALFloysApp from '../components/ALFloysApp';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AL.Floys - Ontogony</title>
    <link rel="icon" type="image/png" href="/logo.png" />
    <meta
      name="description"
      content="Interactive artificial life playground featuring boids, ecosystem evolution, Lenia, and Physarum simulation modes."
    />
    <style is:global>
      html,
      body {
        margin: 0;
        width: 100%;
        height: 100%;
      }
    </style>
  </head>
  <body>
    <ALFloysApp client:only="react" />
  </body>
</html>
