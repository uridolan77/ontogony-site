---
import BaseLayout from '../layouts/BaseLayout.astro';
import ALFloysApp from '../components/ALFloysApp';
---

<BaseLayout
  title="AL.Floys"
  description="Interactive artificial life playground featuring boids, ecosystem evolution, Lenia, Physarum, Turing reaction-diffusion, and N-body gravity."
  kind="PLAYGROUND"
  detail="ARTIFICIAL LIFE"
>
  <header class="al-header">
    <h1>AL.Floys</h1>
    <p class="al-lead">
      An interactive artificial-life laboratory. Six simulation kernels — flocking boids,
      genetic ecosystems, Lenia continuous automata, Physarum slime-mold, Turing
      reaction-diffusion, and N-body gravity — running live in your browser. Double-click
      any particle to track it; use the controls panel to tune physics in real time.
    </p>
  </header>

  <div class="al-embed">
    <ALFloysApp client:only="react" />
  </div>
</BaseLayout>

<style>
  .al-header {
    margin-bottom: 1.5rem;
  }

  .al-header h1 {
    font-family: var(--font-serif, Georgia, serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 400;
    letter-spacing: -0.01em;
    margin: 0 0 0.75rem;
  }

  .al-lead {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-ink-muted, #555);
    max-width: 68ch;
    margin: 0;
  }

  .al-embed {
    position: relative;
    width: 100%;
    height: 80vh;
    min-height: 520px;
    border: 1px solid var(--color-rule, #e0ddd6);
    border-radius: 4px;
    overflow: hidden;
  }
</style>
